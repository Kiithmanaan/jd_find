# 系统配置事实源：src 与 prisma schema 消费的每个环境变量都必须在本文件声明（受 npm run contracts:check 校验）。
# 各变量的生产取值要求见 docs/60-operations-deployment-guide.md 第 3 节。

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jd_search"
PORT=3000
HOST=127.0.0.1
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
SEARCH_RUN_QUEUE_NAME=search-runs
JWT_SECRET=change-me-in-production
RESUME_ATTACHMENT_DIR=
AI_ASSESSMENT_PROVIDER=mock
AI_ASSESSMENT_ENDPOINT=
AI_ASSESSMENT_API_KEY=
AI_ASSESSMENT_PROVIDER_NAME=mock
AI_ASSESSMENT_MODEL=external-ai-assessment
AI_ASSESSMENT_TEMPERATURE=0
AI_ASSESSMENT_MAX_RETRIES=2
AI_ASSESSMENT_TIMEOUT_MS=30000
OPENAI_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
PLUGIN_CANDIDATE_RATE_LIMIT=60
PLUGIN_ATTACHMENT_RATE_LIMIT=30
PLUGIN_RATE_LIMIT_WINDOW_SECONDS=60
