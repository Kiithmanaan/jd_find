generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobProfileStatus {
  Draft
  Suggested
  Confirmed
  Archived
}

enum SearchRunStatus {
  Created
  Running
  Acquired
  Deduplicated
  HardFiltered
  Assessed
  Completed
  Interrupted
  Failed
  Cancelled
}

enum CandidateResultStatus {
  Pending
  Acquired
  Deduplicated
  HardPassed
  HardRejected
  Assessed
  Displayable
}

model UserRecord {
  id                 String   @id
  email              String   @unique
  passwordHash       String
  pluginTokenVersion Int      @default(1)
  createdAt          DateTime @default(now())

  @@index([email])
}

model JobProfileRecord {
  id                String           @id
  createdByUserId   String?
  title             String
  jdText            String
  status            JobProfileStatus
  currentVersionId  String?
  searchCondition   Json
  hardRequirements  Json
  softRequirements  Json
  negativeSignals   Json             @default("[]")
  confirmedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  searchRuns        SearchRunRecord[]
  versions          JobProfileVersionRecord[]
  clarificationInterviews ClarificationInterviewSessionRecord[]

  @@index([status])
}

model JobProfileVersionRecord {
  id                String             @id
  jobProfileId      String
  version           Int
  title             String
  jdText            String
  searchCondition   Json
  hardRequirements  Json
  softRequirements  Json
  negativeSignals   Json               @default("[]")
  status            String
  createdAt         DateTime
  confirmedAt       DateTime?
  jobProfile        JobProfileRecord   @relation(fields: [jobProfileId], references: [id], onDelete: Cascade)
  searchRuns        SearchRunRecord[]

  @@index([jobProfileId])
  @@index([jobProfileId, status])
  @@unique([jobProfileId, version])
}

model SearchRunRecord {
  id                 String                  @id
  jobProfileId       String
  jobProfileVersionId String?
  ownerId            String?
  status             SearchRunStatus
  targetResultCount  Int
  rawSubmittedCount  Int                     @default(0)
  interruptedReason  String?
  failureReason      String?
  events             SearchEventRecord[]
  candidates         CandidateResultRecord[]
  aiAssessmentAudits AIAssessmentAuditRecord[]
  pluginCandidateBatches PluginCandidateBatchRecord[]
  candidateAssessments CandidateAssessmentRecord[]
  createdAt          DateTime
  updatedAt          DateTime
  jobProfile         JobProfileRecord        @relation(fields: [jobProfileId], references: [id])
  jobProfileVersion  JobProfileVersionRecord? @relation(fields: [jobProfileVersionId], references: [id])

  @@index([jobProfileId])
  @@index([jobProfileVersionId])
  @@index([status])
}

model PluginCandidateBatchRecord {
  id             String   @id @default(cuid())
  searchRunId    String
  batchId        String
  requestDigest  String
  candidateCount Int
  status         String
  failureReason  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  searchRun      SearchRunRecord @relation(fields: [searchRunId], references: [id], onDelete: Cascade)

  @@unique([searchRunId, batchId])
  @@index([searchRunId, status])
}

model CandidateAssessmentRecord {
  id                  String   @id
  candidateId         String
  candidateFingerprint String
  searchRunId         String
  jobProfileId        String
  jobProfileVersionId String
  auditId             String?
  assessmentType      String
  assessment          Json
  createdAt           DateTime @default(now())
  searchRun           SearchRunRecord @relation(fields: [searchRunId], references: [id], onDelete: Cascade)

  @@index([candidateFingerprint, jobProfileVersionId, createdAt])
  @@index([searchRunId])
}

model ReassessmentLockRecord {
  id                  String   @id @default(cuid())
  jobProfileId        String
  jobProfileVersionId String
  running             Boolean  @default(true)
  updatedAt           DateTime @updatedAt

  @@unique([jobProfileId, jobProfileVersionId])
}

model AIAssessmentAuditRecord {
  id             String          @id
  searchRunId    String
  jobProfileId   String
  jobProfileVersionId String?
  agentType      String          @default("match-assessment")
  provider       String
  model          String
  promptVersion  String          @default("match-assessment-v1")
  agentVersion   String          @default("jd-match-assessment-v1")
  graphVersion   String?
  prompt         String          @default("")
  candidateIds   Json
  inputSnapshot  Json
  outputSnapshot Json
  durationMs     Int             @default(0)
  status         String          @default("success")
  errorType      String?
  errorMessage   String?
  createdAt      DateTime
  searchRun      SearchRunRecord @relation(fields: [searchRunId], references: [id], onDelete: Cascade)

  @@index([searchRunId])
  @@index([jobProfileId])
  @@index([jobProfileVersionId])
  @@index([provider, model])
}

model CandidateResultRecord {
  id                String                @id
  fingerprint       String
  jobProfileId      String
  searchRunId       String
  status            CandidateResultStatus
  resume            Json
  intent            String
  activityLevel     String
  sourceLead        Json
  hardRejectReasons Json
  matchAssessment   Json?
  resumeAttachment  Json?
  searchRun         SearchRunRecord       @relation(fields: [searchRunId], references: [id], onDelete: Cascade)

  @@index([jobProfileId])
  @@index([searchRunId])
  @@unique([searchRunId, fingerprint])
}

model SearchEventRecord {
  id          String          @id @default(cuid())
  searchRunId String
  type        String
  sequence    Int
  occurredAt  DateTime
  reason      String?
  metadata    Json?
  searchRun   SearchRunRecord @relation(fields: [searchRunId], references: [id], onDelete: Cascade)

  @@index([searchRunId])
  @@index([type])
  @@unique([searchRunId, sequence])
}

model HardConditionDimensionRecord {
  id                  String   @id
  key                 String   @unique
  label               String
  valueType           String
  supportedMatchModes Json
  allowMultiple       Boolean
  createdAt           DateTime @default(now())
  options             HardConditionOptionRecord[]
}

model HardConditionOptionRecord {
  id           String   @id
  dimensionKey String
  value        String
  label        String
  aliases      Json
  rank         Int?
  createdAt    DateTime @default(now())
  dimension    HardConditionDimensionRecord @relation(fields: [dimensionKey], references: [key], onDelete: Cascade)

  @@index([dimensionKey])
  @@unique([dimensionKey, value])
}

model ClarificationInterviewSessionRecord {
  id                String    @id
  jobProfileId      String
  createdByUserId   String?
  status            String
  currentTopicIndex Int       @default(0)
  turns             Json
  draftOutput       Json?
  provider          String
  model             String
  promptVersion     String
  createdAt         DateTime
  updatedAt         DateTime
  completedAt       DateTime?
  jobProfile        JobProfileRecord @relation(fields: [jobProfileId], references: [id], onDelete: Cascade)

  @@index([jobProfileId, status])
}
