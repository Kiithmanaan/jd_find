{
  "name": "jd-search",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "db:down": "docker compose down",
    "db:up": "docker compose up -d postgres redis",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "start": "node dist/src/api/server.js",
    "user:create": "node dist/src/scripts/create-user.js",
    "worker:search": "node dist/src/workers/search-run-worker.js",
    "test": "npm run build && node --test dist/tests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "web:build": "vite build --config web/vite.config.ts",
    "web:dev": "vite --config web/vite.config.ts",
    "web:typecheck": "tsc -p web/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/sensible": "^5.6.0",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.26.2",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "prisma": "^5.22.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  }
}
